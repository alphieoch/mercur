{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["apps/api/src/*"],
      "@/*": ["apps/api/src/*"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"]
}
