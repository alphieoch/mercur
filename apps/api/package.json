{
  "name": "@acme/api",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "exports": {
    "./_generated": {
      "types": "./.mercur/index.d.ts"
    }
  },
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "postinstall": "mkdir -p node_modules/.bin && ln -sf ../../../../packages/cli/dist/index.js node_modules/.bin/mercurjs",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "reindex:typesense": "medusa exec ./src/scripts/reindex-typesense.ts",
    "start": "node ../../packages/cli/dist/index.js start",
    "dev": "node ../../packages/cli/dist/index.js develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit --passWithNoTests"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.26.0",
    "@medusajs/admin-sdk": "2.13.4",
    "@medusajs/admin-shared": "2.13.4",
    "@medusajs/cli": "2.13.4",
    "@medusajs/core-flows": "2.13.4",
    "@medusajs/dashboard": "2.13.4",
    "@medusajs/draft-order": "2.13.4",
    "@medusajs/framework": "2.13.4",
    "@medusajs/medusa": "2.13.4",
    "@medusajs/payment-stripe": "2.13.4",
    "@mercurjs/cli": "*",
    "@mercurjs/core": "*",
    "@mercurjs/payout-stripe-connect": "workspace:*",
    "@mercurjs/types": "*",
    "@types/multer": "^2.1.0",
    "@workos-inc/node": "^9.2.0",
    "http-proxy-middleware": "^3.0.3",
    "meilisearch": "^0.58.0",
    "multer": "^2.1.1",
    "posthog-node": "^5.33.4",
    "typesense": "^3.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.4",
    "@medusajs/utils": "2.13.4",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
